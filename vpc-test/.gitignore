# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which likely contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of
# version control as they are data points which are potentially sensitive
# and subject to change based on the environment where Terraform is executed.
# If you are using a consistent file name for your tfvars, it is safer to
# ignore that exact file name.
# example: terraform.tfvars
*.tfvars
*.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore plan output files generated by `terraform plan -out=tfplan`
# example: *tfplan*

# Optional: ignore graph output files generated by `terraform graph`
# *.dot
